# mock = offline demo (no credits burned) | fireworks = real upstream
UPSTREAM_MODE=mock
UPSTREAM_BASE_URL=https://api.fireworks.ai/inference/v1
UPSTREAM_API_KEY=fw_your_key_here
SLACK_WEBHOOK_URL=
MAAT_ADMIN_TOKEN=
MAAT_REQUIRE_AUTH=
MAAT_INJECT_STREAM_USAGE=true

# AMD Developer Cloud deployment (docker-compose.amd.yml) additionally needs:
# HF_TOKEN=hf_...                      # to pull gated Gemma weights for the vLLM $0 tier
# VLLM_MODEL=google/gemma-3-4b-it      # the Gemma served on the AMD GPU via ROCm
